# Firebase Configuration
# Copy this file to .env.local and fill in your values

# Required Firebase Config (these will be exposed in client bundle - this is normal for Firebase)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional - Measurement ID for Firebase Analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Optional - reCAPTCHA Site Key for App Check (get from Firebase Console)
VITE_RECAPTCHA_SITE_KEY=

# Optional - App Check Mode: "off", "recaptcha", "enterprise", or "debug"
# Use "enterprise" when your site key is from reCAPTCHA Enterprise (recommended for production).
VITE_APP_CHECK_MODE=enterprise

# Optional - Debug token for App Check (only for testing)
VITE_APP_CHECK_DEBUG_TOKEN=

# Social Links
VITE_INSTAGRAM_URL=https://instagram.com/your_handle
